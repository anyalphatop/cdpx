{
  "name": "@anyalphatop/cdpx",
  "version": "1.0.1",
  "description": "Make any website programmable via Chrome CDP.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "bin": {
    "cdpx": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyalphatop/cdpx.git"
  },
  "keywords": [
    "cdp",
    "chrome",
    "automation",
    "cli",
    "devtools"
  ],
  "author": "leaderman",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/anyalphatop/cdpx/issues"
  },
  "homepage": "https://github.com/anyalphatop/cdpx#readme",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
