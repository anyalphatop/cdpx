{
  "name": "@anyalphatop/cdpx",
  "version": "1.0.5",
  "description": "Make any website programmable via Chrome CDP.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "bin": {
    "cdpx": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyalphatop/cdpx.git"
  },
  "keywords": [
    "cdp",
    "chrome",
    "automation",
    "cli",
    "devtools"
  ],
  "author": "leaderman",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/anyalphatop/cdpx/issues"
  },
  "homepage": "https://github.com/anyalphatop/cdpx#readme",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.3",
    "jsdom": "^29.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
